---
import { Brain, FingerprintPattern, Gauge, Waypoints } from "@lucide/astro";
import type { EvidenceKind } from "@/lib/types";

interface Props {
  kind: EvidenceKind;
  label: string;
}

const { kind, label } = Astro.props;
const styles: Record<EvidenceKind, string> = {
  deterministic: "border-deterministic/30 bg-deterministic/10 text-deterministic",
  llm: "border-llm/30 bg-llm/10 text-llm",
  uncertainty: "border-uncertainty/30 bg-uncertainty/10 text-uncertainty",
  provenance: "border-provenance/30 bg-provenance/10 text-provenance"
};
const icons = { deterministic: Gauge, llm: Brain, uncertainty: Waypoints, provenance: FingerprintPattern };
const Icon = icons[kind];
---

<span class:list={["inline-flex items-center gap-1 rounded-md border px-2 py-1 text-xs font-semibold", styles[kind]]}>
  <Icon aria-hidden="true" size={14} />
  {label}
</span>
