# Mosaic non-secret configuration template.
# Copy this file to .env for local development, then fill secrets only in .env.
# Keep model behavior, routing, budgets, and artifact paths in configs/.

OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_BASE_URL=

DATABASE_URL=postgresql://mosaic:mosaic@localhost:5432/mosaic
REDIS_URL=redis://localhost:6379/0
