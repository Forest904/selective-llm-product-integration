---
import FixtureBadge from "./FixtureBadge.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  showFixtureBadge?: boolean;
}

const { eyebrow, title, description, showFixtureBadge = false } = Astro.props;
---

<section class="mx-auto max-w-7xl px-4 pb-8 pt-10 sm:px-6 lg:pt-14">
  <div class="max-w-4xl rise-in">
    <p class="text-sm font-semibold uppercase tracking-wide text-provenance">{eyebrow}</p>
    <h1 class="mt-3 text-4xl font-semibold leading-tight text-ink sm:text-5xl">{title}</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-muted">{description}</p>
  </div>
  {showFixtureBadge && <div class="mt-5"><FixtureBadge /></div>}
  <div class="mt-7">
    <slot />
  </div>
</section>
