---
import PageHeader from "@/components/astro/PageHeader.astro";
import ConceptExplorer from "@/components/ConceptExplorer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Mosaic Concept Explorer">
  <main>
    <PageHeader
      eyebrow="Concept explorer"
      title="Try the decisions that make product integration hard."
      description="Each module isolates one idea from the pipeline and compares deterministic recommendations with bounded LLM evidence."
    />
    <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6">
      <ConceptExplorer />
    </section>
  </main>
</BaseLayout>
