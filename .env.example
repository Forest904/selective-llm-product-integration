# Mosaic non-secret configuration template.

MOSAIC_ENV=development
MOSAIC_RUN_MODE=fixture
MOSAIC_LOG_LEVEL=INFO

MOSAIC_DATA_ROOT=data
MOSAIC_ARTIFACT_ROOT=artifacts
MOSAIC_REPORT_ROOT=reports

MOSAIC_LLM_PROVIDER=
MOSAIC_LLM_MODEL=
MOSAIC_LLM_CACHE_MODE=off

DATABASE_URL=postgresql://mosaic:mosaic@localhost:5432/mosaic
REDIS_URL=redis://localhost:6379/0
