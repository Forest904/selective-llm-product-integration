---
import { CircleCheck } from "@lucide/astro";
import { conceptModules } from "@/lib/demo-data";
---

<div class="grid gap-4 lg:grid-cols-[18rem_1fr]" data-concept-explorer>
  <div class="rounded-lg border border-line bg-panel p-3">
    <p class="text-sm font-semibold text-ink">Modules</p>
    <div class="mt-3 grid gap-2" role="tablist" aria-label="Mosaic concepts">
      {conceptModules.map((module, index) => (
        <button
          type="button"
          role="tab"
          data-module-button={module.id}
          aria-controls={`concept-${module.id}`}
          aria-selected={index === 0 ? "true" : "false"}
          class:list={["min-h-10 rounded-md px-3 text-left text-sm font-semibold", index === 0 ? "bg-ink text-panel" : "bg-white text-ink"]}
        >
          {module.title}
        </button>
      ))}
    </div>
  </div>

  {conceptModules.map((module, index) => (
    <section
      id={`concept-${module.id}`}
      role="tabpanel"
      data-module-panel={module.id}
      hidden={index !== 0}
      class="story-band rounded-lg p-5"
    >
      <p class="text-sm font-semibold uppercase tracking-wide text-provenance">{module.interaction}</p>
      <h2 class="mt-2 text-2xl font-semibold text-ink">{module.title}</h2>
      <p class="mt-3 text-base leading-7 text-muted">{module.prompt}</p>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        {module.options.map((option) => (
          <button
            type="button"
            data-concept-option={option}
            class="min-h-12 rounded-md border border-line bg-white px-3 text-left text-sm font-semibold text-ink"
            aria-pressed="false"
          >
            {option}
          </button>
        ))}
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <div class="rounded-lg border border-deterministic/25 bg-deterministic/10 p-4">
          <p class="text-sm font-semibold text-deterministic">Deterministic recommendation</p>
          <p class="mt-2 text-lg font-semibold text-ink">{module.deterministicAnswer}</p>
        </div>
        <div class="rounded-lg border border-llm/25 bg-llm/10 p-4">
          <p class="text-sm font-semibold text-llm">LLM evidence</p>
          <p class="mt-2 text-lg font-semibold text-ink">{module.llmAnswer}</p>
        </div>
      </div>

      <div data-concept-lesson hidden class="mt-5 flex items-start gap-3 rounded-lg border border-line bg-white p-4" aria-live="polite">
        <CircleCheck aria-hidden="true" class="mt-1 shrink-0 text-deterministic" size={20} />
        <p class="text-sm leading-6 text-muted">{module.lesson}</p>
      </div>
    </section>
  ))}
</div>

<script>
  const initializeConceptExplorer = () => {
    const root = document.querySelector<HTMLElement>("[data-concept-explorer]");
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";
    const selections = new Map<string, string>();

    const activateModule = (moduleId: string) => {
      root.querySelectorAll<HTMLButtonElement>("[data-module-button]").forEach((button) => {
        const active = button.dataset.moduleButton === moduleId;
        button.setAttribute("aria-selected", String(active));
        button.className = `min-h-10 rounded-md px-3 text-left text-sm font-semibold ${active ? "bg-ink text-panel" : "bg-white text-ink"}`;
      });
      root.querySelectorAll<HTMLElement>("[data-module-panel]").forEach((panel) => {
        panel.hidden = panel.dataset.modulePanel !== moduleId;
      });
    };

    root.querySelectorAll<HTMLButtonElement>("[data-module-button]").forEach((button) => {
      button.addEventListener("click", () => activateModule(button.dataset.moduleButton ?? ""));
    });

    root.querySelectorAll<HTMLButtonElement>("[data-concept-option]").forEach((button) => {
      button.addEventListener("click", () => {
        const panel = button.closest<HTMLElement>("[data-module-panel]");
        if (!panel) return;
        const moduleId = panel.dataset.modulePanel ?? "";
        const option = button.dataset.conceptOption ?? "";
        selections.set(moduleId, option);
        panel.querySelectorAll<HTMLButtonElement>("[data-concept-option]").forEach((candidate) => {
          const selected = candidate.dataset.conceptOption === selections.get(moduleId);
          candidate.setAttribute("aria-pressed", String(selected));
          candidate.className = `min-h-12 rounded-md border px-3 text-left text-sm font-semibold text-ink ${selected ? "border-provenance bg-provenance/10" : "border-line bg-white"}`;
        });
        const lesson = panel.querySelector<HTMLElement>("[data-concept-lesson]");
        if (lesson) lesson.hidden = false;
      });
    });
  };

  document.addEventListener("astro:page-load", initializeConceptExplorer);
  initializeConceptExplorer();
</script>
